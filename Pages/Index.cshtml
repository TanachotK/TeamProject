@page
@model IndexModel
@{
    ViewData["Title"] = "Filmhantering";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Lägg till ny film</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="FilmData.Titel" class="form-label">Titel</label>
                            <input asp-for="FilmData.Titel" type="text" class="form-control">
                            <span asp-validation-for="FilmData.Titel" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="FilmData.Genre" class="form-label">Genre</label>
                            <input asp-for="FilmData.Genre" type="text" class="form-control">
                            <span asp-validation-for="FilmData.Genre" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="FilmData.Åldersgräns" class="form-label">Åldersgräns</label>
                            <input asp-for="FilmData.Åldersgräns" type="number" class="form-control">
                            <span asp-validation-for="FilmData.Åldersgräns" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="FilmData.Recension" class="form-label">Recension</label>
                            <textarea asp-for="FilmData.Recension" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="FilmData.Recension" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-primary">Lägg till film</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Alla filmer (@Model.Films.Count)</h5>
                </div>
                <div class="card-body">
                    @if (Model.Films.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Titel</th>
                                        <th>Genre</th>
                                        <th>Åldersgräns</th>
                                        <th>Recension</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var film in Model.Films)
                                    {
                                        <tr>
                                            <td>@film.Titel</td>
                                            <td>@film.Genre</td>
                                            <td>@film.Åldersgräns</td>
                                            <td>@(string.IsNullOrEmpty(film.Recension) ? "-" : film.Recension)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Inga filmer tillagda än.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
