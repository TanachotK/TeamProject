@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<div class="card bg-white">
    <div class="card-body">

        <form method="post">
            <div class="mb-3">
                <label asp-for="FilmData.Titel" class="form-label">Titel</label>
                <input asp-for="FilmData.Titel" type="text" class="form-control">
                <span asp-validation-for="FilmData.Titel" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="FilmData.Genre" class="form-label">Genre</label>
                <input asp-for="FilmData.Genre" type="text" class="form-control">
                <span asp-validation-for="FilmData.Genre" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="FilmData.Åldersgräns" class="form-label">Åldersgräns</label>
                <input asp-for="FilmData.Åldersgräns" type="number" class="form-control">
                <span asp-validation-for="FilmData.Åldersgräns" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="FilmData.Recension" class="form-label">Recension</label>
                <input asp-for="FilmData.Recension" type="text" class="form-control">
                <span asp-validation-for="FilmData.Recension" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Submit</button>
        </form>

        @if (Model.AllSubmissions.Any())
        {
            <div class="mt-3">
                <h5>Submitted Films:</h5>
                @foreach (var film in Model.AllSubmissions)
                {
                    <div class="border p-2 mb-2">
                        <p><strong>Titel:</strong> @film.Titel</p>
                        <p><strong>Genre:</strong> @film.Genre</p>
                        <p><strong>Åldersgräns:</strong> @film.Åldersgräns</p>
                        <p><strong>Recension:</strong> @film.Recension</p>
                    </div>
                }
                <form method="post" asp-page-handler="Reset" class="mt-3">
                    <button type="submit" class="btn btn-secondary">Clear All</button>
                </form>
            </div>
        }

    </div>
</div>